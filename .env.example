# Kelp One-Pager Agent — API keys
# Copy to .env and fill in. Never commit .env.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# LiteLLM gateway (OpenAI-compatible). Fill these to route models via LiteLLM.
# BASE_URL usually ends in /v1, e.g. https://litellm.yourorg.com/v1 or http://localhost:4000/v1
LITELLM_BASE_URL=
LITELLM_API_KEY=
# Model ids your gateway exposes for each tier (may be prefixed, e.g. gemini/gemini-2.5-flash)
LITELLM_FLASH_MODEL=gemini/gemini-2.5-flash
LITELLM_FLASH_LITE_MODEL=gemini/gemini-2.5-flash-lite
