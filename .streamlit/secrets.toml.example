# Streamlit Community Cloud secrets — paste this (with REAL values) into
#   App  ->  Settings  ->  Secrets   on share.streamlit.io
# TOML format: KEY = "value". Do NOT commit the filled-in version.

LITELLM_BASE_URL = "your-litellm-base-url"
LITELLM_API_KEY = "your-litellm-api-key"
LITELLM_FLASH_MODEL = "gemini/gemini-2.5-flash"
LITELLM_FLASH_LITE_MODEL = "gemini/gemini-2.5-flash-lite"
GEMINI_API_KEY = "your-gemini-api-key"
ANTHROPIC_API_KEY = "your-anthropic-api-key"
OPENAI_API_KEY = "your-openai-api-key"
